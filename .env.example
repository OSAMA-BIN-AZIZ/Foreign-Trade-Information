# ===== 基础 =====
APP_ENV=prod
TZ=Asia/Shanghai

# ===== 微信公众号 =====
WECHAT_APP_ID=你的AppID
WECHAT_APP_SECRET=你的AppSecret

# 个人主体建议先固定草稿模式，最稳
WECHAT_USE_DRAFT_ONLY=true

WECHAT_AUTHOR=你的署名
WECHAT_NEED_OPEN_COMMENT=0
WECHAT_ONLY_FANS_CAN_COMMENT=0
WECHAT_IMAGE_UPLOAD_MODE=auto

# ===== 发布策略 =====
# 即使你后面把 WECHAT_USE_DRAFT_ONLY 改成 false，
# 也建议先保留 safe_auto，权限不足会自动降级到草稿
PUBLISH_MODE=safe_auto
PUBLISH_CRON=0 8 * * *

# ===== 存储与输出 =====
OUTPUT_DIR=./data/output
STATE_DB=./data/state.sqlite3

# ===== 汇率源 =====
# auto: 先实时拉取，失败后走缓存/演示值
EXCHANGE_RATE_PROVIDER=auto
EXCHANGE_RATE_BASE=CNY
EXCHANGE_RATE_TIMEOUT=8

# ===== 网络代理（中国网络环境建议配置） =====
# OUTBOUND_PROXY_MODE: auto(先直连失败再代理) | on(强制代理) | off(强制直连)
OUTBOUND_PROXY_MODE=auto
OUTBOUND_HTTP_PROXY=http://127.0.0.1:10808

# ===== 新闻源 =====
NEWS_SOURCE_MODE=rss
# 兼容旧配置；建议留空并使用下方分组源
NEWS_RSS_URLS=
NEWS_CN_RSS_URLS=https://www.chinanews.com.cn/rss/scroll-news.xml
NEWS_GLOBAL_RSS_URLS=https://news.un.org/feed/subscribe/en/news/all/rss.xml,https://www.aljazeera.com/xml/rss/all.xml
NEWS_FETCH_TIMEOUT=8
# 建议 8~20，若希望更多可再提高
NEWS_MAX_ITEMS=20
NEWS_MIN_ITEMS=20
# 至少保留多少条国内资讯
NEWS_CN_MIN_ITEMS=4

# ===== 封面与文摘 =====
COVER_IMAGE_PATH=./assets/cover-default.jpg
DEFAULT_THUMB_DIGEST=每日外贸与跨境资讯速览

# ===== 告警（可选） =====
WEBHOOK_NOTIFY_URL=
